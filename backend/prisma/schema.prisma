generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "auth"]
}

enum CompanyRole {
  company_admin
  user

  @@map("company_role")
  @@schema("public")
}

enum ExecutionStatus {
  pending
  running
  completed
  failed
  paused

  @@map("execution_status")
  @@schema("public")
}

enum LogType {
  Info
  Success
  Error

  @@map("log_type")
  @@schema("public")
}

enum DecisionNodeType {
  Human
  Agent
  Agent_Human

  @@map("decision_node_type")
  @@schema("public")
}

model User {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email              String    @unique
  encrypted_password String?
  email_confirmed_at DateTime? @db.Timestamptz(6)
  created_at         DateTime  @default(now()) @db.Timestamptz(6)
  updated_at         DateTime  @default(now()) @db.Timestamptz(6)
  profile            Profile?
  records_created    DataTableRecord[]

  @@map("users")
  @@schema("auth")
}

model Company {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String
  created_at            DateTime               @default(now()) @db.Timestamptz(6)
  api_key               String?                @unique
  is_active             Boolean?               @default(true)
  slug                  String?                @unique
  logo_url              String?
  logo_storage_path     String?
  portal_description    String?
  portal_primary_color  String?
  portal_enabled        Boolean                @default(false)
  agent_permissions     AgentPermission[]
  api_configurations    ApiConfiguration[]
  global_variables      DataGlobalVariable[]
  tables                DataTable[]
  table_fields          DataTableField[]
  records               DataTableRecord[]
  folders               Folder[]
  files                 File[]
  metadata_keys         FilesMetadataKey[]
  metadata_values       FilesMetadataValue[]
  profile_groups        ProfileGroup[]
  folder_permissions    FolderPermission[]
  invitations           Invitation[]
  notifications         Notification[]
  user_companies        UserCompany[]
  workflow_categories   WorkflowCategory[]
  workflows             Workflow[]
  workflow_statuses     WorkflowStatus[]
  workflow_steps        WorkflowStep[]
  workflow_executions   WorkflowExecution[]
  execution_steps       WorkflowExecutionStep[]
  agent_usage           AgentUsage[]
  workflow_connections  WorkflowConnection[]
  workflow_execution_data WorkflowExecutionData[]
  workflow_execution_logs WorkflowExecutionLog[]
  workflow_files        WorkflowFile[]
  workflow_permissions  WorkflowPermission[]

  @@map("companies")
  @@schema("public")
}

model Profile {
  id                    String                @id @db.Uuid
  email                 String
  full_name             String?
  created_at            DateTime              @default(now()) @db.Timestamptz(6)
  updated_at            DateTime              @default(now()) @db.Timestamptz(6)
  notifications_enabled Boolean?              @default(true)
  user                  User                  @relation(fields: [id], references: [id])
  admin_role            ProfileAdminRole?
  files_uploaded        File[]
  profile_groups_created ProfileGroup[]
  folder_permissions    FolderPermission[]
  invitations_sent      Invitation[]
  notifications         Notification[]
  group_memberships     ProfileGroupMember[]
  user_companies        UserCompany[]
  workflow_steps        WorkflowStep[]
  workflow_executions   WorkflowExecution[]
  execution_steps       WorkflowExecutionStep[]
  workflow_permissions  WorkflowPermission[]

  @@map("profiles")
  @@schema("public")
}

model AgentCategory {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  description    String?
  icon           String?
  created_at     DateTime             @default(now()) @db.Timestamptz(6)
  updated_at     DateTime             @default(now()) @db.Timestamptz(6)
  configurations AgentConfiguration[]

  @@map("agent_categories")
  @@schema("public")
}

model AgentConfiguration {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String
  description       String?
  api_url           String
  api_method        String            @default("POST")
  api_headers       Json?             @default("[]")
  api_params        Json?             @default("[]")
  created_at        DateTime          @default(now()) @db.Timestamptz(6)
  updated_at        DateTime          @default(now()) @db.Timestamptz(6)
  category_id       String?           @db.Uuid
  agent_type        String?
  category          AgentCategory?    @relation(fields: [category_id], references: [id])
  permissions       AgentPermission[]
  usage             AgentUsage[]

  @@map("agent_configurations")
  @@schema("public")
}

model AgentPermission {
  id                     String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agent_configuration_id String             @db.Uuid
  company_id             String             @db.Uuid
  enabled                Boolean            @default(true)
  created_at             DateTime           @default(now()) @db.Timestamptz(6)
  agent_configuration    AgentConfiguration @relation(fields: [agent_configuration_id], references: [id])
  company                Company            @relation(fields: [company_id], references: [id])

  @@map("agent_permissions")
  @@schema("public")
}

model ApiConfiguration {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  config_type String
  api_url     String
  api_method  String   @default("POST")
  api_headers Json?    @default("[]")
  api_params  Json?    @default("[]")
  api_data    Json?    @default("[]")
  company_id  String   @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)
  company     Company  @relation(fields: [company_id], references: [id])

  @@map("api_configurations")
  @@schema("public")
}

model DataGlobalVariable {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id    String   @db.Uuid
  name          String
  key           String?
  variable_type String
  options       Json?    @default("{}")
  position      Int      @default(0)
  value         Json?
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @default(now()) @db.Timestamptz(6)
  is_locked     Boolean  @default(false)
  company       Company  @relation(fields: [company_id], references: [id])

  @@map("data_global_variables")
  @@schema("public")
}

model DataTable {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  description      String?
  position         Int              @default(0)
  company_id       String           @db.Uuid
  created_at       DateTime         @default(now()) @db.Timestamptz(6)
  updated_at       DateTime         @default(now()) @db.Timestamptz(6)
  primary_field_id String?          @db.Uuid
  company          Company          @relation(fields: [company_id], references: [id])
  fields           DataTableField[] @relation("TableFields")
  primary_field    DataTableField?  @relation("PrimaryField", fields: [primary_field_id], references: [id])
  records          DataTableRecord[]

  @@map("data_tables")
  @@schema("public")
}

model DataTableField {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  table_id      String      @db.Uuid
  name          String
  field_type    String
  options       Json?
  position      Int         @default(0)
  is_required   Boolean     @default(false)
  company_id    String      @db.Uuid
  created_at    DateTime    @default(now()) @db.Timestamptz(6)
  updated_at    DateTime    @default(now()) @db.Timestamptz(6)
  table         DataTable   @relation("TableFields", fields: [table_id], references: [id])
  company       Company     @relation(fields: [company_id], references: [id])
  primary_for   DataTable[] @relation("PrimaryField")

  @@map("data_table_fields")
  @@schema("public")
}

model DataTableRecord {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  table_id   String    @db.Uuid
  data       Json      @default("{}")
  created_by String?   @db.Uuid
  company_id String    @db.Uuid
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @db.Timestamptz(6)
  position   Int       @default(0)
  table      DataTable @relation(fields: [table_id], references: [id])
  creator    User?     @relation(fields: [created_by], references: [id])
  company    Company   @relation(fields: [company_id], references: [id])

  @@map("data_table_records")
  @@schema("public")
}

model Folder {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  description      String?
  parent_folder_id String?            @db.Uuid
  company_id       String?            @db.Uuid
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime           @default(now()) @db.Timestamptz(6)
  parent_folder    Folder?            @relation("FolderHierarchy", fields: [parent_folder_id], references: [id])
  sub_folders      Folder[]           @relation("FolderHierarchy")
  company          Company?           @relation(fields: [company_id], references: [id])
  files            File[]
  permissions      FolderPermission[]

  @@map("folders")
  @@schema("public")
}

model File {
  id              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  description     String?
  folder_id       String               @db.Uuid
  storage_path    String
  mime_type       String?
  size_bytes      BigInt?
  uploaded_by     String?              @db.Uuid
  company_id      String?              @db.Uuid
  created_at      DateTime             @default(now()) @db.Timestamptz(6)
  updated_at      DateTime             @default(now()) @db.Timestamptz(6)
  folder          Folder               @relation(fields: [folder_id], references: [id])
  uploader        Profile?             @relation(fields: [uploaded_by], references: [id])
  company         Company?             @relation(fields: [company_id], references: [id])
  metadata_values FilesMetadataValue[]
  workflow_files  WorkflowFile[]

  @@map("files")
  @@schema("public")
}

model FilesMetadataKey {
  id              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String?
  company_id      String?              @db.Uuid
  created_at      DateTime             @default(now()) @db.Timestamptz(6)
  updated_at      DateTime             @default(now()) @db.Timestamptz(6)
  company         Company?             @relation(fields: [company_id], references: [id])
  metadata_values FilesMetadataValue[]

  @@map("files_metadata_keys")
  @@schema("public")
}

model FilesMetadataValue {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  files_id    String           @db.Uuid
  metadata_id String           @db.Uuid
  value       String
  company_id  String           @db.Uuid
  created_at  DateTime         @default(now()) @db.Timestamptz(6)
  updated_at  DateTime         @default(now()) @db.Timestamptz(6)
  file        File             @relation(fields: [files_id], references: [id])
  metadata    FilesMetadataKey @relation(fields: [metadata_id], references: [id])
  company     Company          @relation(fields: [company_id], references: [id])

  @@map("files_metadata_values")
  @@schema("public")
}

model ProfileGroup {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String
  description        String?
  company_id         String?              @db.Uuid
  created_by         String?              @db.Uuid
  created_at         DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at         DateTime?            @default(now()) @db.Timestamptz(6)
  company            Company?             @relation(fields: [company_id], references: [id])
  creator            Profile?             @relation(fields: [created_by], references: [id])
  folder_permissions FolderPermission[]
  members            ProfileGroupMember[]
  workflow_steps     WorkflowStep[]
  execution_steps    WorkflowExecutionStep[]
  workflow_permissions WorkflowPermission[]

  @@map("profile_groups")
  @@schema("public")
}

model FolderPermission {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  folder_id       String      @db.Uuid
  user_id         String?     @db.Uuid
  group_id        String?     @db.Uuid
  permission_type String
  company_id      String?     @db.Uuid
  created_at      DateTime    @default(now()) @db.Timestamptz(6)
  folder          Folder      @relation(fields: [folder_id], references: [id])
  user            Profile?    @relation(fields: [user_id], references: [id])
  group           ProfileGroup? @relation(fields: [group_id], references: [id])
  company         Company?    @relation(fields: [company_id], references: [id])

  @@map("folder_permissions")
  @@schema("public")
}

model Invitation {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id  String      @db.Uuid
  email       String
  token       String      @unique
  role        CompanyRole @default(user)
  invited_by  String      @db.Uuid
  status      String      @default("pending")
  created_at  DateTime    @default(now()) @db.Timestamptz(6)
  company     Company     @relation(fields: [company_id], references: [id])
  inviter     Profile     @relation(fields: [invited_by], references: [id])

  @@map("invitations")
  @@schema("public")
}

model Notification {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  company_id String?  @db.Uuid
  title      String
  message    String
  type       String
  data       Json?    @default("{}")
  is_read    Boolean? @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  user       Profile  @relation(fields: [user_id], references: [id])
  company    Company? @relation(fields: [company_id], references: [id])

  @@map("notifications")
  @@schema("public")
}

model ProfileAdminRole {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id  String   @unique @db.Uuid
  super_admin Boolean  @default(false)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)
  profile     Profile  @relation(fields: [profile_id], references: [id])

  @@map("profile_admin_roles")
  @@schema("public")
}

model ProfileGroupMember {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  group_id   String?      @db.Uuid
  profile_id String?      @db.Uuid
  created_at DateTime?    @default(now()) @db.Timestamptz(6)
  group      ProfileGroup? @relation(fields: [group_id], references: [id])
  profile    Profile?     @relation(fields: [profile_id], references: [id])

  @@map("profile_group_members")
  @@schema("public")
}

model TriggerSetting {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  setting_key   String   @unique
  setting_value String
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @default(now()) @db.Timestamptz(6)

  @@map("trigger_settings")
  @@schema("public")
}

model UserCompany {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String      @db.Uuid
  company_id String      @db.Uuid
  role       CompanyRole @default(user)
  created_at DateTime    @default(now()) @db.Timestamptz(6)
  profile    Profile     @relation(fields: [user_id], references: [id])
  company    Company     @relation(fields: [company_id], references: [id])

  @@map("user_company")
  @@schema("public")
}

model WorkflowCategory {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String
  description        String?
  parent_category_id String?            @db.Uuid
  icon               String?
  company_id         String             @db.Uuid
  created_at         DateTime           @default(now()) @db.Timestamptz(6)
  updated_at         DateTime           @default(now()) @db.Timestamptz(6)
  parent_category    WorkflowCategory?  @relation("CategoryHierarchy", fields: [parent_category_id], references: [id])
  sub_categories     WorkflowCategory[] @relation("CategoryHierarchy")
  company            Company            @relation(fields: [company_id], references: [id])
  workflows          Workflow[]

  @@map("workflow_categories")
  @@schema("public")
}

model Workflow {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String
  description       String?
  created_at        DateTime           @default(now()) @db.Timestamptz(6)
  updated_at        DateTime           @default(now()) @db.Timestamptz(6)
  company_id        String?            @db.Uuid
  file_enabled      Boolean            @default(false)
  is_public         Boolean            @default(false)
  visibility_scope  String             @default("all_company")
  start_permission_scope String        @default("public")
  api_enabled       Boolean            @default(false)
  data_structure    Json?              @default("[]")
  category_id       String?            @db.Uuid
  icon              String?
  default_status_id String?            @db.Uuid
  is_active         Boolean?           @default(false)
  portal_enabled    Boolean            @default(false)
  canvas_comments   Json?
  company           Company?           @relation(fields: [company_id], references: [id])
  category          WorkflowCategory?  @relation(fields: [category_id], references: [id])
  default_status    WorkflowStatus?    @relation("DefaultStatus", fields: [default_status_id], references: [id])
  statuses          WorkflowStatus[]   @relation("WorkflowStatuses")
  steps             WorkflowStep[]
  executions        WorkflowExecution[]
  connections       WorkflowConnection[]
  workflow_files    WorkflowFile[]
  permissions       WorkflowPermission[]

  @@map("workflows")
  @@schema("public")
}

model WorkflowStatus {
  id                 String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workflow_id        String      @db.Uuid
  name               String
  order              Int
  color              String
  created_at         DateTime    @default(now()) @db.Timestamptz(6)
  updated_at         DateTime    @default(now()) @db.Timestamptz(6)
  company_id         String?     @db.Uuid
  workflow           Workflow    @relation("WorkflowStatuses", fields: [workflow_id], references: [id])
  default_for        Workflow[]  @relation("DefaultStatus")
  company            Company?    @relation(fields: [company_id], references: [id])

  @@map("workflow_statuses")
  @@schema("public")
}

model WorkflowStep {
  id                   String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workflow_id          String            @db.Uuid
  step_type            String
  name                 String
  position_x           Decimal           @default(0) @db.Decimal
  position_y           Decimal           @default(0) @db.Decimal
  config               Json?             @default("{}")
  created_at           DateTime          @default(now()) @db.Timestamptz(6)
  updated_at           DateTime          @default(now()) @db.Timestamptz(6)
  assigned_to_user_id  String?           @db.Uuid
  assigned_to_group_id String?           @db.Uuid
  decision_node_type   DecisionNodeType?
  company_id           String?           @db.Uuid
  action_type          String?           @default("manual")
  workflow             Workflow          @relation(fields: [workflow_id], references: [id])
  assigned_user        Profile?          @relation(fields: [assigned_to_user_id], references: [id])
  assigned_group       ProfileGroup?     @relation(fields: [assigned_to_group_id], references: [id])
  company              Company?          @relation(fields: [company_id], references: [id])
  executions           WorkflowExecution[]
  execution_steps      WorkflowExecutionStep[]
  connections_source   WorkflowConnection[] @relation("SourceStep")
  connections_target   WorkflowConnection[] @relation("TargetStep")

  @@map("workflow_steps")
  @@schema("public")
}

model WorkflowExecution {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workflow_id     String            @db.Uuid
  status          ExecutionStatus   @default(pending)
  started_at      DateTime?         @db.Timestamptz(6)
  completed_at    DateTime?         @db.Timestamptz(6)
  current_step_id String?           @db.Uuid
  created_by      String?           @db.Uuid
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  updated_at      DateTime          @default(now()) @db.Timestamptz(6)
  company_id      String?           @db.Uuid
  execution_data  Json?             @default("{}")
  name            String?
  workflow        Workflow          @relation(fields: [workflow_id], references: [id])
  current_step    WorkflowStep?     @relation(fields: [current_step_id], references: [id])
  creator         Profile?          @relation(fields: [created_by], references: [id])
  company         Company?          @relation(fields: [company_id], references: [id])
  execution_steps WorkflowExecutionStep[]
  usage           AgentUsage[]
  execution_data_records WorkflowExecutionData[]
  execution_logs   WorkflowExecutionLog[]

  @@map("workflow_executions")
  @@schema("public")
}

model WorkflowExecutionStep {
  id                   String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  execution_id         String            @db.Uuid
  step_id              String            @db.Uuid
  status               ExecutionStatus   @default(pending)
  started_at           DateTime?         @db.Timestamptz(6)
  completed_at         DateTime?         @db.Timestamptz(6)
  step_data            Json?             @default("{}")
  decision_choice      String?
  assigned_to_user_id  String?           @db.Uuid
  assigned_to_group_id String?           @db.Uuid
  created_at           DateTime          @default(now()) @db.Timestamptz(6)
  updated_at           DateTime          @default(now()) @db.Timestamptz(6)
  company_id           String?           @db.Uuid
  external_token       String?           @db.Uuid
  execution            WorkflowExecution @relation(fields: [execution_id], references: [id])
  step                 WorkflowStep      @relation(fields: [step_id], references: [id])
  assigned_user        Profile?          @relation(fields: [assigned_to_user_id], references: [id])
  assigned_group       ProfileGroup?     @relation(fields: [assigned_to_group_id], references: [id])
  company              Company?          @relation(fields: [company_id], references: [id])
  execution_logs       WorkflowExecutionLog[]

  @@map("workflow_execution_steps")
  @@schema("public")
}

model AgentUsage {
  id                    String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workflow_execution_id String?             @db.Uuid
  agent_id              String?             @db.Uuid
  model_name            String?
  input_tokens          BigInt?
  thinking_tokens       BigInt?
  output_tokens         BigInt?
  total_cost            Decimal?            @db.Decimal
  company_id            String?             @db.Uuid
  comment               String?            @db.Text
  created_at            DateTime            @default(now()) @db.Timestamptz(6)
  execution             WorkflowExecution?  @relation(fields: [workflow_execution_id], references: [id])
  agent                 AgentConfiguration? @relation(fields: [agent_id], references: [id])
  company               Company?            @relation(fields: [company_id], references: [id])

  @@map("agent_usage")
  @@schema("public")
}

model WorkflowConnection {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workflow_id    String        @db.Uuid
  source_step_id String        @db.Uuid
  target_step_id String        @db.Uuid
  output_name    String?       @default("default")
  created_at     DateTime      @default(now()) @db.Timestamptz(6)
  updated_at     DateTime      @default(now()) @db.Timestamptz(6)
  company_id     String?       @db.Uuid
  config         Json?
  workflow       Workflow      @relation(fields: [workflow_id], references: [id])
  source_step    WorkflowStep  @relation("SourceStep", fields: [source_step_id], references: [id])
  target_step    WorkflowStep  @relation("TargetStep", fields: [target_step_id], references: [id])
  company        Company?      @relation(fields: [company_id], references: [id])

  @@map("workflow_connections")
  @@schema("public")
}

model WorkflowExecutionData {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  execution_id String            @db.Uuid
  company_id   String?           @db.Uuid
  created_at   DateTime          @default(now()) @db.Timestamptz(6)
  updated_at   DateTime          @default(now()) @db.Timestamptz(6)
  values       Json?             @default("{}")
  execution    WorkflowExecution @relation(fields: [execution_id], references: [id])
  company      Company?          @relation(fields: [company_id], references: [id])

  @@map("workflow_execution_data")
  @@schema("public")
}

model WorkflowExecutionLog {
  id           String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id   String                 @db.Uuid
  execution_id String                 @db.Uuid
  log_text     String
  created_at   DateTime               @default(now()) @db.Timestamptz(6)
  step_id      String?                @db.Uuid
  log_type     LogType?
  execution    WorkflowExecution      @relation(fields: [execution_id], references: [id])
  company      Company                @relation(fields: [company_id], references: [id])
  step         WorkflowExecutionStep? @relation(fields: [step_id], references: [id], map: "workflow_execution_log_step_id_fkey")

  @@map("workflow_execution_log")
  @@schema("public")
}

model WorkflowFile {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workflow_id String   @db.Uuid
  file_id     String   @db.Uuid
  company_id  String?  @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  workflow    Workflow @relation(fields: [workflow_id], references: [id])
  file        File     @relation(fields: [file_id], references: [id])
  company     Company? @relation(fields: [company_id], references: [id])

  @@map("workflow_files")
  @@schema("public")
}

model WorkflowPermission {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workflow_id     String   @db.Uuid
  user_id         String?  @db.Uuid
  group_id        String?  @db.Uuid
  permission_type String
  company_id      String?  @db.Uuid
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  workflow        Workflow @relation(fields: [workflow_id], references: [id])
  user            Profile? @relation(fields: [user_id], references: [id])
  group           ProfileGroup? @relation(fields: [group_id], references: [id])
  company         Company? @relation(fields: [company_id], references: [id])

  @@map("workflow_permissions")
  @@schema("public")
}
