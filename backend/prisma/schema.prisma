generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "auth"]
}

enum CompanyRole {
  company_admin
  user

  @@map("company_role")
  @@schema("public")
}

enum FilesMetadataValueKind {
  free_text
  predefined_list

  @@map("files_metadata_value_kind")
  @@schema("public")
}

model User {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email              String    @unique
  encrypted_password String?
  email_confirmed_at DateTime? @db.Timestamptz(6)
  created_at         DateTime  @default(now()) @db.Timestamptz(6)
  updated_at         DateTime  @default(now()) @db.Timestamptz(6)
  profile            Profile?

  @@map("users")
  @@schema("auth")
}

model Company {
  id                         String                         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                       String
  created_at                 DateTime                       @default(now()) @db.Timestamptz(6)
  api_key                    String?                        @unique
  is_active                  Boolean?                       @default(true)
  slug                       String?                        @unique
  logo_url                   String?
  logo_storage_path          String?
  internal_logo_url          String?
  internal_logo_storage_path String?
  internal_primary_color     String?
  portal_description         String?
  portal_primary_color       String?
  portal_enabled             Boolean                        @default(false)
  portal_default_language    String                         @default("en")
  portal_enabled_languages   Json                           @default("[\"en\"]")
  folders                    Folder[]
  files                      File[]
  metadata_keys              FilesMetadataKey[]
  metadata_values            FilesMetadataValue[]
  profile_groups             ProfileGroup[]
  folder_permissions         FolderPermission[]
  invitations                Invitation[]
  notifications              Notification[]
  user_companies             UserCompany[]
  roles                      Role[]
  audit_logs                 AuditLog[]
  document_permission_rules  DocumentPermissionRule[]
  document_permission_assignments DocumentPermissionAssignment[]
  user_document_tree_configs UserDocumentTreeConfig[]
  document_types             DocumentType[]
  file_history_events        FileHistoryEvent[]
  persons                    Person[]

  @@map("companies")
  @@schema("public")
}

model Profile {
  id                              String                         @id @db.Uuid
  email                           String
  full_name                       String?
  created_at                      DateTime                       @default(now()) @db.Timestamptz(6)
  updated_at                      DateTime                       @default(now()) @db.Timestamptz(6)
  notifications_enabled           Boolean?                       @default(true)
  user                            User                           @relation(fields: [id], references: [id])
  admin_role                      ProfileAdminRole?
  files_uploaded                  File[]
  profile_groups_created          ProfileGroup[]
  folder_permissions              FolderPermission[]
  invitations_sent                Invitation[]
  notifications                   Notification[]
  group_memberships               ProfileGroupMember[]
  user_companies                  UserCompany[]
  document_permission_assignments DocumentPermissionAssignment[]
  document_tree_configs           UserDocumentTreeConfig[]
  file_history_events_as_actor    FileHistoryEvent[]             @relation("FileHistoryActor")

  @@map("profiles")
  @@schema("public")
}

model Folder {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  description      String?
  parent_folder_id String?            @db.Uuid
  company_id       String?            @db.Uuid
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime           @default(now()) @db.Timestamptz(6)
  parent_folder    Folder?            @relation("FolderHierarchy", fields: [parent_folder_id], references: [id])
  sub_folders      Folder[]           @relation("FolderHierarchy")
  company          Company?           @relation(fields: [company_id], references: [id])
  files            File[]
  permissions      FolderPermission[]
  person_root      Person?            @relation("PersonRootFolder")

  @@map("folders")
  @@schema("public")
}

model File {
  id              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  description     String?
  folder_id       String?              @db.Uuid
  storage_path    String
  mime_type       String?
  size_bytes      BigInt?
  uploaded_by     String?              @db.Uuid
  company_id      String?              @db.Uuid
  created_at      DateTime             @default(now()) @db.Timestamptz(6)
  updated_at      DateTime             @default(now()) @db.Timestamptz(6)
  is_archived     Boolean              @default(false)
  archived_datetime DateTime?          @db.Timestamptz(6)

  ocr_markdown     String?   @db.Text
  ocr_status       String?
  ocr_error        String?   @db.Text
  ocr_processed_at DateTime? @db.Timestamptz(6)
  ocr_provider     String?
  ocr_model        String?

  ocr_pending_metadata_key_ids Json?
  metadata_ai_extract_status   String?
  metadata_ai_extract_error      String?   @db.Text

  person_id        String?              @db.Uuid
  document_type_id String?              @db.Uuid

  folder          Folder?              @relation(fields: [folder_id], references: [id])
  uploader        Profile?             @relation(fields: [uploaded_by], references: [id])
  company         Company?             @relation(fields: [company_id], references: [id])
  person          Person?              @relation("PersonFiles", fields: [person_id], references: [id])
  document_type   DocumentType?        @relation("DocumentTypeFiles", fields: [document_type_id], references: [id])
  metadata_values FilesMetadataValue[]
  history_events  FileHistoryEvent[]

  @@index([is_archived, archived_datetime], map: "idx_files_archive")
  @@map("files")
  @@schema("public")
}

model FileHistoryEvent {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id  String   @db.Uuid
  file_id     String   @db.Uuid
  event_type  String
  actor_id    String?  @db.Uuid
  details     Json?
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  company     Company  @relation(fields: [company_id], references: [id], onDelete: Restrict)
  file        File     @relation(fields: [file_id], references: [id], onDelete: Cascade)
  actor       Profile? @relation("FileHistoryActor", fields: [actor_id], references: [id], onDelete: SetNull)

  @@index([file_id, created_at(sort: Desc)], map: "idx_file_history_events_file_created")
  @@map("file_history_events")
  @@schema("public")
}

model FilesMetadataKey {
  id              String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String?
  company_id      String?                 @db.Uuid
  value_kind      FilesMetadataValueKind  @default(free_text)
  allowed_values  Json                    @default("[]")
  created_at      DateTime                @default(now()) @db.Timestamptz(6)
  updated_at      DateTime                @default(now()) @db.Timestamptz(6)
  company         Company?                @relation(fields: [company_id], references: [id])
  metadata_values FilesMetadataValue[]

  @@map("files_metadata_keys")
  @@schema("public")
}

model FilesMetadataValue {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  files_id    String           @db.Uuid
  metadata_id String           @db.Uuid
  value       String
  company_id  String           @db.Uuid
  created_at  DateTime         @default(now()) @db.Timestamptz(6)
  updated_at  DateTime         @default(now()) @db.Timestamptz(6)
  file        File             @relation(fields: [files_id], references: [id])
  metadata    FilesMetadataKey @relation(fields: [metadata_id], references: [id])
  company     Company          @relation(fields: [company_id], references: [id])

  @@map("files_metadata_values")
  @@schema("public")
}

model Person {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id     String   @db.Uuid
  full_name      String
  national_id    String?
  notes          String?  @db.Text
  root_folder_id String?  @unique @db.Uuid
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  updated_at     DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  company        Company  @relation(fields: [company_id], references: [id])
  root_folder    Folder?  @relation("PersonRootFolder", fields: [root_folder_id], references: [id])
  files          File[]   @relation("PersonFiles")

  @@index([company_id, created_at(sort: Desc)], map: "idx_persons_company_created")
  @@map("persons")
  @@schema("public")
}

model ProfileGroup {
  id                              String                         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                            String
  description                     String?
  company_id                      String?                        @db.Uuid
  created_by                      String?                        @db.Uuid
  created_at                      DateTime?                      @default(now()) @db.Timestamptz(6)
  updated_at                      DateTime?                      @default(now()) @db.Timestamptz(6)
  company                         Company?                       @relation(fields: [company_id], references: [id])
  creator                         Profile?                       @relation(fields: [created_by], references: [id])
  folder_permissions              FolderPermission[]
  members                         ProfileGroupMember[]
  document_permission_assignments DocumentPermissionAssignment[]

  @@map("profile_groups")
  @@schema("public")
}

model FolderPermission {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  folder_id       String        @db.Uuid
  user_id         String?       @db.Uuid
  group_id        String?       @db.Uuid
  permission_type String
  company_id      String?       @db.Uuid
  created_at      DateTime      @default(now()) @db.Timestamptz(6)
  folder          Folder        @relation(fields: [folder_id], references: [id])
  user            Profile?      @relation(fields: [user_id], references: [id])
  group           ProfileGroup? @relation(fields: [group_id], references: [id])
  company         Company?      @relation(fields: [company_id], references: [id])

  @@map("folder_permissions")
  @@schema("public")
}

model Invitation {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id String      @db.Uuid
  email      String
  token      String      @unique
  role       CompanyRole @default(user)
  invited_by String      @db.Uuid
  status     String      @default("pending")
  created_at DateTime    @default(now()) @db.Timestamptz(6)
  company    Company     @relation(fields: [company_id], references: [id])
  inviter    Profile     @relation(fields: [invited_by], references: [id])

  @@map("invitations")
  @@schema("public")
}

model Notification {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  company_id String?  @db.Uuid
  title      String
  message    String
  type       String
  data       Json?    @default("{}")
  is_read    Boolean? @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  user       Profile  @relation(fields: [user_id], references: [id])
  company    Company? @relation(fields: [company_id], references: [id])

  @@map("notifications")
  @@schema("public")
}

model ProfileAdminRole {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id  String   @unique @db.Uuid
  super_admin Boolean  @default(false)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)
  profile     Profile  @relation(fields: [profile_id], references: [id])

  @@map("profile_admin_roles")
  @@schema("public")
}

model ProfileGroupMember {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  group_id   String?       @db.Uuid
  profile_id String?       @db.Uuid
  created_at DateTime?     @default(now()) @db.Timestamptz(6)
  group      ProfileGroup? @relation(fields: [group_id], references: [id])
  profile    Profile?      @relation(fields: [profile_id], references: [id])

  @@map("profile_group_members")
  @@schema("public")
}

model UserCompany {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String      @db.Uuid
  company_id     String      @db.Uuid
  role           CompanyRole @default(user)
  custom_role_id String?     @db.Uuid
  created_at     DateTime    @default(now()) @db.Timestamptz(6)
  profile        Profile     @relation(fields: [user_id], references: [id])
  company        Company     @relation(fields: [company_id], references: [id])
  custom_role    Role?       @relation(fields: [custom_role_id], references: [id])

  @@map("user_company")
  @@schema("public")
}

model Role {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  company_id  String           @db.Uuid
  is_system   Boolean          @default(false)
  created_at  DateTime         @default(now()) @db.Timestamptz(6)
  updated_at  DateTime         @default(now()) @updatedAt @db.Timestamptz(6)
  company     Company          @relation(fields: [company_id], references: [id])
  permissions RolePermission[]
  users       UserCompany[]

  @@unique([company_id, name])
  @@map("roles")
  @@schema("public")
}

model RolePermission {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role_id        String   @db.Uuid
  permission_key String
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  role           Role     @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@unique([role_id, permission_key])
  @@map("role_permissions")
  @@schema("public")
}

model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id  String   @db.Uuid
  actor_id    String   @db.Uuid
  action      String
  target_type String
  target_id   String   @db.Uuid
  details     Json?
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  company     Company  @relation(fields: [company_id], references: [id])

  @@map("audit_logs")
  @@schema("public")
}

model DocumentPermissionRule {
  id              String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  company_id      String                        @db.Uuid
  permission_type String                        @default("read")
  conditions      Json                          @default("[]")
  created_at      DateTime                      @default(now()) @db.Timestamptz(6)
  updated_at      DateTime                      @default(now()) @updatedAt @db.Timestamptz(6)
  company         Company                       @relation(fields: [company_id], references: [id])
  assignments     DocumentPermissionAssignment[]

  @@map("document_permission_rules")
  @@schema("public")
}

model DocumentPermissionAssignment {
  id         String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rule_id    String                 @db.Uuid
  user_id    String?                @db.Uuid
  group_id   String?                @db.Uuid
  company_id String                 @db.Uuid
  created_at DateTime               @default(now()) @db.Timestamptz(6)
  rule       DocumentPermissionRule @relation(fields: [rule_id], references: [id], onDelete: Cascade)
  user       Profile?               @relation(fields: [user_id], references: [id])
  group      ProfileGroup?          @relation(fields: [group_id], references: [id])
  company    Company                @relation(fields: [company_id], references: [id])

  @@map("document_permission_assignments")
  @@schema("public")
}

model UserDocumentTreeConfig {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String   @db.Uuid
  company_id      String   @db.Uuid
  key_order       Json     @default("[]")
  hide_key_labels Boolean  @default(false)
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  user            Profile  @relation(fields: [user_id], references: [id])
  company         Company  @relation(fields: [company_id], references: [id])

  @@unique([user_id, company_id])
  @@map("user_document_tree_configs")
  @@schema("public")
}

model DocumentType {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id          String   @db.Uuid
  name                String
  naming_instructions String   @db.Text
  metadata_key_ids    Json     @default("[]")
  created_at          DateTime @default(now()) @db.Timestamptz(6)
  updated_at          DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  company             Company  @relation(fields: [company_id], references: [id])
  files               File[]   @relation("DocumentTypeFiles")

  @@index([company_id, created_at], map: "idx_document_types_company_created_at")
  @@map("document_types")
  @@schema("public")
}
