{
  "name": "@lexora/backend",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "start": "npm run migrate:deploy && node dist/index.js",
    "dev": "npm run migrate:deploy && nodemon --watch 'src/**/*.ts' --exec 'ts-node --transpile-only' src/index.ts",
    "build": "npx prisma generate --schema=./prisma/schema.prisma && tsc",
    "migrate:deploy": "node ./scripts/migrate.js",
    "migrate:dev": "prisma migrate dev",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@prisma/client": "^5.22.0",
    "@sendgrid/mail": "^7.7.0",
    "@yourapp/shared": "*",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "eventsource": "^4.1.0",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "form-data": "^4.0.0",
    "jsonwebtoken": "^9.0.2",
    "minio": "^8.0.6",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.11",
    "@types/node": "^18.15.11",
    "@types/node-fetch": "^2.6.4",
    "@types/supertest": "^6.0.3",
    "jest": "^30.2.0",
    "nodemon": "^2.0.22",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.4"
  }
}
