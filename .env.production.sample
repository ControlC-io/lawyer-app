# Production environment variables for Coolify.
# Copy-paste into Coolify → Environment Variables.
# Replace every value marked with CHANGE_ME.

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=lawyer_app_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:CHANGE_ME_strong_db_password@db:5432/lawyer_app_db

# ── Backend ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_32_char_random_string
INTERNAL_API_KEY=CHANGE_ME_internal_key
SUPER_ADMIN_API_KEY=CHANGE_ME_super_admin_key
ENABLE_PUBLIC_SIGNUP=false
APP_URL=https://CHANGE_ME_your_domain.com
BACKEND_URL=https://CHANGE_ME_your_domain.com

# ── OCR (Mistral) ────────────────────────────────────────────────────────────
OCR_API_KEY=CHANGE_ME_mistral_api_key
OCR_PROVIDER=mistral
OCR_MODEL=mistral-ocr-latest
OCR_API_URL=https://api.mistral.ai/v1/ocr

# ── PDF split (Gemini) ────────────────────────────────────────────────────────
GEMINI_API_KEY=CHANGE_ME_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# ── MinIO (internal only — not exposed to the internet) ──────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=CHANGE_ME_minio_user
MINIO_SECRET_KEY=CHANGE_ME_minio_password
MINIO_BUCKET_NAME=lexora-app
# Signed file URLs are proxied through the backend — leave these empty
# unless MinIO is exposed publicly on its own domain.
MINIO_PUBLIC_URL=
MINIO_EXTERNAL_ENDPOINT=
MINIO_SIGNED_URL_MAX_AGE=604800

# ── Email (SendGrid) — optional ───────────────────────────────────────────────
SENDGRID_API_KEY=
FROM_EMAIL=noreply@CHANGE_ME_your_domain.com
APP_NAME=Lexora

# ── Frontend (build-time) ─────────────────────────────────────────────────────
# Empty = frontend uses relative /api URLs, nginx routes to backend.
# Do NOT set to http://127.0.0.1:3001 or any absolute URL.
VITE_API_URL=
