# Copy this file to .env and set real values. .env is gitignored and must not be committed.
# Usage: cp .env.sample .env

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=floowly_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@db:5432/floowly_db

# Backend
PORT=3001
NODE_ENV=development
JWT_SECRET=your-jwt-secret-change-me
INTERNAL_API_KEY=internal-trigger-key-change-me
# Super admin API key: server-side only. When set, requests with header x-super-admin-api-key: <key> get super_admin access (e.g. list all companies). Never use client-side.
SUPER_ADMIN_API_KEY=
ENABLE_PUBLIC_SIGNUP="false"
APP_URL=http://localhost
# Public URL of the API (used e.g. for document links in API responses). In prod set to your API origin, e.g. https://automate.floowly.app
BACKEND_URL=http://localhost:3001

# MinIO
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=floowly
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_EXTERNAL_ENDPOINT=
MINIO_SIGNED_URL_MAX_AGE=604800

# Email (SendGrid)
SENDGRID_API_KEY=
FROM_EMAIL=noreply@floowly.app
FEEDBACK_EMAIL=contact@controlc.io
DEMO_REQUEST_EMAIL=contact@controlc.io

# Frontend (Vite, used at build time)
VITE_API_URL=http://localhost:3001

# Optional: AI services
OPENAI_API_KEY=
LOVABLE_API_KEY=
FLOOWLY_AI_VALIDATION_API_KEY=
AI_FORM_VALIDATION_URL=https://automation.floowly.app/webhook/7604f736-0ea8-4ec1-9b03-082256e42e0c
