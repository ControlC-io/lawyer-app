# Copy this file to .env and set real values. .env is gitignored and must not be committed.
# Usage: cp .env.sample .env

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=lawyer_app_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@db:5432/lawyer_app_db
# When running migrations from Windows/macOS host (outside Docker), use localhost instead of db:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lawyer_app_db

# Backend
PORT=3001
NODE_ENV=development
JWT_SECRET=your-jwt-secret-change-me
INTERNAL_API_KEY=internal-trigger-key-change-me
# Super admin API key: server-side only. Send via x-api-key or x-super-admin-api-key for full resource access.
SUPER_ADMIN_API_KEY=
ENABLE_PUBLIC_SIGNUP="false"
APP_URL=http://localhost
# Public URL of the API (used e.g. for document links in API responses).
BACKEND_URL=http://localhost:3001

# OCR
OCR_API_KEY=your-mistral-api-key-here
OCR_PROVIDER=mistral
OCR_MODEL=mistral-ocr-latest
OCR_API_URL=https://api.mistral.ai/v1/ocr

# PDF split (Gemini proposes page ranges from OCR text; requires Google AI Studio key)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash


# MinIO
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=lawyer-app
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_EXTERNAL_ENDPOINT=
MINIO_SIGNED_URL_MAX_AGE=604800

# Email (SendGrid)
SENDGRID_API_KEY=
FROM_EMAIL=noreply@example.com
APP_NAME=Lawyer App
FEEDBACK_EMAIL=contact@controlc.io
DEMO_REQUEST_EMAIL=contact@controlc.io

# Frontend (Vite, used at build time)
VITE_API_URL=http://localhost:3001

# Optional: legacy AI keys (not required for document OCR/split)
OPENAI_API_KEY=
