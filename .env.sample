# Copy to .env and set real values. Never commit .env (gitignored).
# Usage: cp .env.sample .env
#
# --- Pick ONE dev mode ---
#
# A) Docker full stack (backend + frontend in containers):
#    DATABASE_URL host = db, MINIO_ENDPOINT = minio, VITE_API_URL empty
#    docker compose up -d
#
# B) Host dev (recommended on Windows): DB + MinIO in Docker, app on host
#    DATABASE_URL host = localhost, MINIO_ENDPOINT = localhost, VITE_API_URL = http://127.0.0.1:3001
#    docker compose up -d db minio backend
#    .\scripts\dev-local.ps1

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dossier_app_db
POSTGRES_PORT=5432
# Docker: @db:5432 — host dev: @localhost:5432
DATABASE_URL=postgresql://postgres:postgres@db:5432/dossier_app_db

# Backend
PORT=3001
NODE_ENV=development
JWT_SECRET=your-jwt-secret-change-me
# Internal service auth (x-internal-api-key header)
INTERNAL_API_KEY=internal-api-key-change-me
SUPER_ADMIN_API_KEY=
ENABLE_PUBLIC_SIGNUP=false
APP_URL=http://localhost
BACKEND_URL=http://localhost:3001

# OCR (Mistral)
OCR_API_KEY=your-mistral-api-key-here
OCR_PROVIDER=mistral
OCR_MODEL=mistral-ocr-latest
OCR_API_URL=https://api.mistral.ai/v1/ocr

# PDF split (Gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# MinIO — Docker: minio — host dev: localhost
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=dossier-app
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_EXTERNAL_ENDPOINT=
MINIO_SIGNED_URL_MAX_AGE=604800

# Email (SendGrid) — invitations; optional if SENDGRID_API_KEY is empty
SENDGRID_API_KEY=
FROM_EMAIL=noreply@example.com
APP_NAME=Dossier

# Frontend — Docker: leave empty (compose proxies /api). Host dev: http://127.0.0.1:3001
VITE_API_URL=
